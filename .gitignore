node_modules/
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment variables (NEVER commit secrets!)
.env
.env.*
!.env.example
*.pem
*.key

# Build outputs
.next/
out/
build/
dist/

# Testing
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# Caches
.cache/
.parcel-cache/
.turbo/
.vercel/

# Database / Uploads (data files shouldn't be in git)

*.db
*.sqlite
*.sqlite3

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*
