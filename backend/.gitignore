# ========================================
# Dependencies (รัน npm install ใหม่ได้)
# ========================================
node_modules/
.pnp
.pnp.*
.npm
.yarn-integrity

# ========================================
# Secrets & Environment (ห้ามขึ้น Git!)
# ========================================
# มี: MONGODB_URI, JWT_SECRET, CLAUDE_API_KEY, GEMINI_API_KEY
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
!.env.example

# Keys & Certificates
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
private/
secrets/

# ========================================
# Build / Compile output
# ========================================
dist/
build/
out/
lib/
*.tsbuildinfo

# ========================================
# Logs
# ========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ========================================
# Testing & Coverage
# ========================================
coverage/
*.lcov
.nyc_output/
junit.xml
test-results/

# ========================================
# Uploads (ไฟล์ PDF/TXT จากผู้ใช้ — ไม่ควรอยู่ใน repo)
# ========================================
uploads/*
upload/
files/
attachments/
tmp/
temp/
!uploads/.gitkeep

# ========================================
# Database files (MongoDB ใช้ external server แต่กันไว้)
# ========================================
*.db
*.sqlite
*.sqlite3
data/
mongodb-data/
db-backup/
dump/

# ========================================
# Cache
# ========================================
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.tsbuildinfo

# ========================================
# OS-generated files
# ========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ========================================
# Editor / IDE
# ========================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# ========================================
# Process / Runtime
# ========================================
*.pid
*.seed
*.pid.lock
.node_repl_history

# ========================================
# Lock files (เลือกใช้ตัวเดียว — แนะนำ commit package-lock.json)
# ========================================
# yarn.lock
# pnpm-lock.yaml
