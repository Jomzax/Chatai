PORT=4000
MONGO_URI=mongodb://localhost:27017/chatai
FRONTEND_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=chat_ai.sid
SESSION_TTL_SECONDS=86400
BCRYPT_SALT_ROUNDS=12
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX_REQUESTS=20
API_KEY_COOLDOWN_MS=60000
CHAT_TIMEOUT_MS=30000
CHAT_MAX_OUTPUT_TOKENS=1000
CHAT_TEMPERATURE=0.85

# AI providers. Use either a single key or comma-separated keys for rotation.
GEMINI_API_KEY=
GEMINI_API_KEYS=key1,key2,key3
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEYS=key1,key2,key3
CLAUDE_MODEL=claude-3-5-haiku-latest

# Demo admin account. The backend creates it on startup if it does not exist.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Admin
